{% from "hmrc/components/internal-header/macro.njk"  import hmrcInternalHeader %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}

{% set navigationItems = [] %}

{% for section in navigation %}
  {% set isSectionActive = filepath.startsWith(section.href) %}
  {% set isSectionCurrent = filepath === section.href ~ "/" %}
  {% set subsection = '' %}

  {% if section.items and isSectionActive %}
    {% set subsection %}
      <a href="/{{- section.href -}}/"
        class="govuk-service-navigation__link"
        {%- if isSectionActive or isSectionCurrent %} aria-current="{{ 'page' if isSectionCurrent else 'true' }}"{% endif %}
      >{{ section.text }}</a>
      <span class="app-mobile-subnav">
        {% for placement, items in section.items | groupby("placement") %}
          <ul class="app-mobile-subnav__section {{placement}}">
            {% for topic, items in items | groupby("topic") %}
                {% if topic !== 'none' %}
                  <li class="app-mobile-subnav__topic-item">
                    <h3 class="app-mobile-subnav__topic-heading">{{ topic }}</h3>

                    <ul class="app-mobile-subnav__topic-list">
                {% endif %}

                {% for item in items %}
                  {% set isItemCurrent = filepath === item.href ~ "/" %}
                  <li class="app-mobile-subnav__section-item {%- if isItemCurrent %} app-mobile-subnav__section-item--active{% endif %}">
                    <a
                      class="govuk-service-navigation__link"
                      href="/{{- item.href -}}/"
                      {%- if isItemCurrent %} aria-current="page"{% endif %}
                    >{{item.text}}</a>
                  </li>
                {% endfor %}

                {% if topic !== 'none' %}
                  </ul>
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        {% endfor %}
      </span>
    {% endset %}
  {% endif %}

  {% set navigationItems = (navigationItems.push({
    href: ("/" ~ section.href ~ "/" if not subsection or not isSectionActive),
    text: section.text,
    html: (subsection if subsection or isSectionActive),
    active: isSectionActive,
    current: isSectionCurrent
  }), navigationItems) %}
{% endfor %}

{{ hmrcInternalHeader({
  homepageUrl: 'https://www.gov.uk/government/organisations/hm-revenue-customs',
  serviceName: serviceName,
  serviceUrl: '/'
}) }}

{{ govukServiceNavigation({ navigation: navigationItems }) }}

